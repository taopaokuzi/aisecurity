{
  "name": "aisecurity",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo scaffold for the Agent Identity & Permission system",
  "workspaces": [
    "apps/web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "api:dev": "python -m apps.api",
    "worker:dev": "python -m apps.worker",
    "worker:health": "python -m apps.worker.healthcheck",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:start": "npm --prefix apps/web run start",
    "web:lint": "npm --prefix apps/web run lint"
  }
}
